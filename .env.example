# Discord bot token (required)
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Unciv server base URL (used when UNCIV_GAME_URL_TEMPLATE is not set)
UNCIV_SERVER_BASE_URL=https://uncivserver.xyz

# Optional direct endpoint template. Must include {game_id}
# Example: https://uncivserver.xyz/files/{game_id}
UNCIV_GAME_URL_TEMPLATE=https://uncivserver.xyz/files/{game_id}

# Request timeout in seconds
UNCIV_REQUEST_TIMEOUT=15

# Tracking poll interval in seconds (min 30, max 1800)
UNCIV_TRACK_POLL_INTERVAL_SEC=90

# Tracking state file path
UNCIV_TRACK_FILE=tracked_games.json

# Set true to enable legacy prefix commands (!ping, !unciv ...)
# Keep false if Message Content intent is not enabled in Discord Developer Portal.
ENABLE_MESSAGE_CONTENT_INTENT=false
